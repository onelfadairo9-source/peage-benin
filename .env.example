# Copiez ce fichier en .env et remplissez vos vraies valeurs
# Ne JAMAIS committer le fichier .env (clés secrètes) dans Git

PORT=3000
NODE_ENV=development

# Secret pour signer les sessions (générez une longue chaîne aléatoire)
SESSION_SECRET=change_moi_avec_une_longue_chaine_aleatoire_et_secrete

# Clés Kkiapay - récupérables sur https://app.kkiapay.me/dashboard
# En mode test, utilisez vos clés "Sandbox" et laissez KKIAPAY_SANDBOX=true
KKIAPAY_PUBLIC_KEY=votre_cle_publique_kkiapay
KKIAPAY_PRIVATE_KEY=votre_cle_privee_kkiapay
KKIAPAY_SECRET=votre_secret_kkiapay
KKIAPAY_SANDBOX=true

# Identifiants du premier compte admin (créé automatiquement au 1er démarrage)
ADMIN_EMAIL=admin@peage-benin.bj
ADMIN_PASSWORD=changez_ce_mot_de_passe
